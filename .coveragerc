[run]
omit =
    # CLI training script — exercised by train-smoke CI job, not unit tests
    lip/train_all.py
    # Data generation scripts — CLI tools, no unit tests by convention
    lip/dgen/*
    # Integration test requiring live Redis/Kafka — excluded from unit CI
    lip/tests/test_e2e_pipeline.py
    # Load test harness — not a unit test
    lip/tests/load/*

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
